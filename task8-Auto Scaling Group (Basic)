resource "aws_launch_template" "lt" {
  name_prefix   = "example"
  image_id      = "ami-0f58b397bc5c1f2e8"
  instance_type = "t2.micro"
}

resource "aws_autoscaling_group" "asg" {
  desired_capacity = 1
  max_size         = 2
  min_size         = 1

  launch_template {
    id      = aws_launch_template.lt.id
    version = "$Latest"
  }

  vpc_zone_identifier = [aws_subnet.subnet1.id]
}
